{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": false,
    "skipLibCheck": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": "."
  },
  "include": [
    "react-shim.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "shell/src/**/*.ts",
    "shell/src/**/*.tsx",
    "instrument/src/**/*.ts",
    "instrument/src/**/*.tsx",
    "icons/src/**/*.ts",
    "icons/src/**/*.tsx"
  ]
}